PORT=5000
MONGODB_URI=mongodb://localhost:27017/ai-college-platform
JWT_SECRET=your_jwt_secret
NODE_ENV=development

# Cloudinary Config
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# OCR.space Config
OCR_SPACE_API_KEY=your_ocr_api_key

# Gemini AI Config
GEMINI_API_KEY=your_gemini_api_key
# Email Config (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM_NAME="College Study Assistant"
EMAIL_FROM_ADDRESS=noreply@example.com
EMAIL_LOGO_URL=https://your-public-logo-url.png/logo.png
EMAIL_WATERMARK_URL=https://your-public-watermark-url.png/logo_watermark.png
